{
  "name": "domovoid",
  "version": "0.0.0",
  "private": true,
  "description": "AI Agent runtime for connecting claude (and other LLMs) to different channels and tools",
  "license": "MIT",
  "author": "Artur Udalov <artur.udalov@gmail.com>",
  "homepage": "https://github.com/darkartur/domovoid#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkartur/domovoid.git"
  },
  "bugs": {
    "url": "https://github.com/darkartur/domovoid/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.16.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node ./packages/cli/src/index.ts",
    "build": "pnpm run -r prepublishOnly",
    "tsc": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fmt": "prettier --write .",
    "knip": "knip",
    "depcheck": "syncpack lint",
    "depfix": "syncpack fix",
    "verdaccio": "verdaccio --config ./verdaccio-config.yml",
    "coverage:clean": "node ./scripts/coverage-tools/clean.ts",
    "coverage:normalize": "node ./scripts/coverage-tools/normalize.ts",
    "test": "node ./scripts/coverage-tools/clean.ts && playwright test",
    "test:packaged": "CLI_PATH=test-sandbox playwright test",
    "test:coverage": "node ./scripts/coverage-tools/clean.ts && playwright test && node ./scripts/coverage-tools/normalize.ts && c8 report",
    "coverage:check": "node ./scripts/coverage-tools/normalize.ts && c8 report"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@domovoid/cli": "workspace:*",
    "@types/node": "^25.3.0",
    "c8": "^10.1.3",
    "eslint": "^9.20.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-playwright": "^2.7.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "knip": "^5.85.0",
    "prettier": "^3.5.0",
    "syncpack": "^14.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.24.0",
    "verdaccio": "^5.33.0"
  }
}
